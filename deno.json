{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.18"
  },
  "tasks": {
    "run": "deno run -A src/main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/main.ts",
    "test": "deno test src/"
  },
  "fmt": {
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
